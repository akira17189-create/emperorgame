// ---- 四、辅助函数 ----
export function getVoiceForNPC(npcId: string): NPCVoice | undefined {
  return NPC_VOICES[npcId];
}

export function buildVoicePrompt(npcId: string): string {
  const voice = NPC_VOICES[npcId];
  if (!voice) return "";
  
  let prompt = `【${npcId}的说话风格】\n`;
  prompt += `特征：${voice.features.join('、')}\n`;
  prompt += `句式习惯：\n`;
  voice.syntax_rules.forEach(rule => {
    prompt += `- ${rule}\n`;
  });
  prompt += `禁用表达：${voice.forbidden_phrases.join('、')}\n`;
  if (voice.signature_phrase) {
    prompt += `标志性口头禅："${voice.signature_phrase}"\n`;
  }
  return prompt;
}

