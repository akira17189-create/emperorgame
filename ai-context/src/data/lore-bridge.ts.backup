// ---- 四、辅助函数 ----

/** 获取NPC的voice数据，优先从lore-bridge取，fallback到NPC自身voice字段 */
export function getVoiceForNPC(npcId: string, npcVoice?: any): NPCVoice {
  const bridgeVoice = NPC_VOICES[npcId];
  if (bridgeVoice && bridgeVoice.features[0] !== "TODO: DeepSeek填充") {
    return bridgeVoice;
  }
  // fallback到NPC自身voice字段
  if (npcVoice?.features?.length > 0) {
    return npcVoice;
  }
  return {
    features: ["谨慎", "守礼"],
    syntax_rules: ["语气平和，不轻易表态"],
    forbidden_phrases: []
  };
}

/** 将voice数据转成Prompt注入字符串 */
export function buildVoicePrompt(voice: NPCVoice, npcName: string): string {
  let prompt = `\n【${npcName}的说话风格】\n`;
  prompt += `人格特征：${voice.features.join('、')}\n`;
  prompt += `句式规则：\n`;
  voice.syntax_rules.forEach(r => { prompt += `  - ${r}\n`; });
  if (voice.forbidden_phrases.length > 0) {
    prompt += `绝对禁止使用：${voice.forbidden_phrases.join('、')}\n`;
  }
  if (voice.signature_phrase) {
    prompt += `标志性口头禅：「${voice.signature_phrase}」\n`;
  }
  return prompt;
}
