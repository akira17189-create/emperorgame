      "多用'是'、'遵命'、'明白'",
      "汇报时按时间顺序：'辰时发现，午时追踪，酉时抓获'",
      "从不评价，只陈述事实"
    ],
    forbidden_phrases: ["我认为", "大概", "可能", "猜测"],
    signature_phrase: "人在诏狱。活口。"
  },

  // 李静斋 — 江南巨商，暗中资助玩家
  "li-jingzhai": {
    features: ["商人思维", "利益计算", "低调谨慎", "长线投资", "情报网络"],
    syntax_rules: [
      "自称'小人'，但谈生意时语气强硬",
      "用商贾比喻朝政：'这买卖……风险大，但利润更高'",
      "不提具体人名，用'江南的朋友'、'北边的伙伴'",
      "讨价还价式谈判：'小人可以出这个数，但需要陛下……'"
    ],
    forbidden_phrases: ["爱国", "大义", "不计代价", "无偿"],
    signature_phrase: "陛下，这是一笔投资。小人相信，陛下的回报率……会很高。"
  },

  // 柳如是 — 秦淮名妓，情报网核心，玩家红颜知己
  "liu-rushi": {
    features: ["才情过人", "察言观色", "身世飘零", "用美色交易", "内心矛盾"],
    syntax_rules: [
      "说话像唱词，有韵律感",
      "用诗词典故传递信息：'昨夜西风凋碧树……有些树，是该修剪了'",
      "真话假话混杂，让人难辨",
      "涉及自身时突然转为直白"
    ],
    forbidden_phrases: ["我爱你", "真心", "永远", "从良"],
    signature_phrase: "陛下听曲吗？这曲子……词是旧的，调子，我新谱的。"
  },

  // 赵怀安 — 边军总兵，军方实力派，观望中
  "zhao-huaian": {
    features: ["军人傲气", "务实强硬", "厌恶文官", "重视袍泽", "待价而沽"],
    syntax_rules: [
      "自称'末将'，但站得笔直",
      "开口必谈军事：'粮草、兵械、士气'",
      "用战场比喻：'这朝堂，比草原上的狼群还难对付'",
      "直来直去，不耐烦兜圈子"
    ],
    forbidden_phrases: ["政治", "权谋", "妥协", "从长计议"],
    signature_phrase: "陛下，边关的将士，只认两样东西：粮饷，和能带他们打胜仗的将军。"
  },

  // 慧明 — 高僧，佛教代表，与国师对立
  "hui-ming": {
    features: ["悲悯平和", "以柔克刚", "智慧长者", "与世无争", "暗中较劲"],
    syntax_rules: [
      "自称'老衲'，语速缓慢",
      "用佛经故事讲道理：'昔有国王……'",
      "从不直接反对，只说'另一条路'",
      "结尾必是'阿弥陀佛'"
    ],
    forbidden_phrases: ["斗争", "胜负", "必须", "立即"],
    signature_phrase: "陛下，放下，方能提起。"
  }
};

// ---- 四、辅助函数 ----
export function getVoiceForNPC(npcId: string): NPCVoice | undefined {
  return NPC_VOICES[npcId];
}

export function buildVoicePrompt(npcId: string): string {
  const voice = NPC_VOICES[npcId];
  if (!voice) return "";
  
  let prompt = `【${npcId}的说话风格】\n`;
  prompt += `特征：${voice.features.join('、')}\n`;
  prompt += `句式习惯：\n`;
  voice.syntax_rules.forEach(rule => {
    prompt += `- ${rule}\n`;
  });
  prompt += `禁用表达：${voice.forbidden_phrases.join('、')}\n`;
  if (voice.signature_phrase) {
    prompt += `标志性口头禅："${voice.signature_phrase}"\n`;
  }
  return prompt;
}

