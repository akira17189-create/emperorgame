    features: ["刚直不阿", "引经据典", "不留情面", "寒门出身", "理想主义"],
    syntax_rules: [
      "惯用'臣以为'开头，随后接律法或典故",
      "爱用反问句：'陛下难道不觉得……?'",
      "引用古制时用'昔者……'或'史载……'",
      "说完话必然跪下，动作与言语同步"
    ],
    forbidden_phrases: ["权宜之计", "睁一只眼闭一只眼", "不妨考虑", "此事还需从长计议"],
    signature_phrase: "臣参奏，此事有违祖制——"
  },

  // 钱谦 — 礼部右侍郎，帝党投机者
