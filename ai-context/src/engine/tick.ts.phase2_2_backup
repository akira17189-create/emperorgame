/**
 * 检查游戏结束条件
 * @param state 游戏状态
 * @returns 游戏是否结束及原因
 */
export function checkGameEndConditions(state: GameState): { isEnded: boolean; reason?: string } {
  // TODO: 实现游戏结束条件检查
  if (state.resources.food <= 0) {
    return { isEnded: true, reason: '粮食耗尽，饥荒爆发' };
  }
  
  if (state.resources.morale <= 0) {
    return { isEnded: true, reason: '民心尽失，爆发起义' };
  }
  
  if (state.resources.military <= 0) {
    return { isEnded: true, reason: '兵力耗尽，外敌入侵' };
  }
  
  return { isEnded: false };
}

// Phase 2.1 核心实现

/**
 * 应用时间推进
 * @param state 游戏状态
 */
function applyTimeEvolution(state: GameState): void {
  state.world.year += 1;
  state.emperor.age += 1;
  state.world.weather_this_year = Math.random();

  // 每25年增加一代
  if (state.world.year % 25 === 0) {
    state.emperor.generation += 1;
  }
}

/**
 * 应用核心资源规则（只处理6个核心资源）
 * @param resources 资源对象
 */
function applyCoreResourceRules(resources: Resources): void {
  // 只处理6个核心资源：food, population, fiscal, military, morale, threat

  // 粮食生产与消耗
  resources.food = clamp(
    resources.food + (resources.agri_pop * resources.land_fertility * 0.2 - resources.population * 0.05),
    0, 10000
  );

  // 人口自然变化
  resources.population = clamp(
    resources.population + (resources.morale - 50) * 0.1,
    0, 100000
  );

  // 财政收入与支出
  resources.fiscal = clamp(
    resources.fiscal + (resources.tax_rate * resources.population * 0.12 - resources.military_cost - resources.disaster_relief),
    0, 100000
  );

  // 军事变化
  resources.military = clamp(
    resources.military - (resources.threat * 0.5),
    0, 10000
  );

  // 民心变化
  resources.morale = clamp(
    resources.morale + (100 - resources.tax_rate * 200 - resources.faction * 0.5) * 0.1,
    0, 100
  );

  // 威胁演变
  resources.threat = clamp(
    resources.threat + 2 + (100 - resources.military) * 0.05,
    0, 100
  );

  // 军事成本计算
  resources.military_cost = clamp(
    resources.military * 0.02,
    0, 1000
  );

  // 经济变化
  resources.commerce = clamp(
    resources.commerce + (100 - resources.threat) * 0.5,
    0, 10000
  );

  // 土地肥力变化
  resources.land_fertility = clamp(
    resources.land_fertility * (0.95 + resources.weather_this_year * 0.1),
    0, 1
  );

  // 宦官影响派系
  resources.eunuch = clamp(
    resources.eunuch + resources.faction * 0.2,
    0, 100
  );

  // 派系受宦官影响
  resources.faction = clamp(
    resources.faction + resources.eunuch * 0.2,
    0, 100
  );
}

/**
 * 应用NPC行为（从外部读取规则）
 * @param npcs NPC数组
 * @param state 游戏状态
 * @param rules NPC行为规则数组
 */
function applyNpcBehaviors(npcs: NPC[], state: GameState, rules: any[]): void {
  rules.forEach(rule => {
    npcs.forEach(npc => {
      if (rule.condition(npc, state)) {
        const changes = rule.effect(npc, state);
        // 应用changes到state
        applyChanges(state, changes);
      }
    });
  });
}

