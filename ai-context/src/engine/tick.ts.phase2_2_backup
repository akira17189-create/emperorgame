/**
 * 执行一个时间刻度的演算
 * @param state 当前游戏状态
 * @param options 演算选项
 * @returns 演算结果
 */
export function executeTick(state: GameState, options: TickOptions = {}): TickResult {
  const newState = JSON.parse(JSON.stringify(state)) as GameState;
  const events: string[] = [];
  const warnings: string[] = [];

  try {
    // 1. 时间推进
    applyTimeEvolution(newState);

    // 2. 核心资源规则（只处理6个核心资源）
    applyCoreResourceRules(newState.resources);

    // 3. NPC行为（从外部读取规则）
    // 注意：这里需要导入npcBehaviorRules，将在core-characters.ts中定义
    // applyNpcBehaviors(newState.npcs, newState, npcBehaviorRules);

    // 4. 收集日志
    // const logs = collectChangeLogs();

    // 5. 检查游戏结束条件
    const endCondition = checkGameEndConditions(newState);
    if (endCondition.isEnded) {
      warnings.push(`游戏结束: ${endCondition.reason}`);
    }

    return {
      success: true,
      newState,
      events,
      warnings
    };

  } catch (error) {
    console.error('Tick执行错误:', error);
    return {
      success: false,
      newState: state,
      events: [],
      warnings: [`Tick执行失败: ${error}`]
    };
  }
}

